<script>
let currentTranspose = 0;

function transpose(step) {
  currentTranspose += step;
  const parser = new ChordSheetJS.ChordProParser();
  const song = parser.parse(document.getElementById("song").innerText);
  const formatter = new ChordSheetJS.HtmlDivFormatter();
  const transposed = song.transpose(currentTranspose);
  document.getElementById("song").innerHTML = formatter.format(transposed);
}
</script>

